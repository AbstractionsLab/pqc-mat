{
	"name": "VECTOR Dev Container",
	"build": {
		"context": "..",
		"dockerfile": "../dev.Dockerfile"
	},
	"workspaceFolder": "/home/vector/vector-project",
	"workspaceMount": "source=${localWorkspaceFolder},target=/home/vector/vector-project,type=bind",
	"postCreateCommand": "pip install black",
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"ms-python.black-formatter",
				"streetsidesoftware.code-spell-checker"
			],
			"settings": {
				"python.formatting.provider": "black",
				"cSpell.enabled": true
			}
		}
	},
	"overrideCommand": false
}